# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# next.js config (site statique — pas de build)
next.config.ts
eslint.config.mjs
tsconfig.json
package-lock.json

# claude / outils locaux
.claude/

# Fichiers sources lourds (Photoshop, Illustrator) — non déployables
*.psd
*.ai
public/Photos avec signalétique/
BUT 2 Stage/
# PDF source > 100 MB
public/assets/carnet ACD GMP 4.pdf
